# Node
TZ=UTC
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# Database (PostgreSQL)
#--------------------------------------------------------------------
DB_CONNECTION=pg
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=locate_me

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

#--------------------------------------------------------------------
# WebSocket (real-time location broadcasts)
#--------------------------------------------------------------------
WS_HOST=0.0.0.0
WS_PORT=5001
# Comma-separated origins allowed to connect over WS.
# Use * in development to allow any origin.
WS_ALLOWED_ORIGINS=*
